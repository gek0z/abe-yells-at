{
  "name": "abe-yells",
  "private": true,
  "workspaces": ["packages/*", "apps/*"],
  "scripts": {
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "ci": "biome ci .",
